{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/relay\" hook codex",
            "statusMessage": "session-relay: registering + draining inbox"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/relay\" hook codex --event prompt",
            "statusMessage": "session-relay: checking inbox"
          }
        ]
      }
    ]
  }
}
